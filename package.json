{
  "name": "@liangrk/claude-code-wechatbot",
  "version": "0.3.1",
  "description": "Claude Code Channel plugin for WeChat — bridge WeChat messages into Claude Code sessions via the official ilink API",
  "type": "module",
  "bin": {
    "claude-code-wechat-channel": "cli.mjs"
  },
  "files": [
    "cli.mjs",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build wechat-channel.ts --target node --outfile dist/wechat-channel.js && bun build setup.ts --target node --outfile dist/setup.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.5.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liangrk/claude-code-wechat-channel.git"
  },
  "keywords": [
    "claude-code",
    "wechat",
    "mcp",
    "channel",
    "clawbot",
    "ai-agent"
  ]
}
