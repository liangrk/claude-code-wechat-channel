{
  "name": "@liangrk/claude-code-wechatbot",
  "version": "0.4.0",
  "description": "WeChat Bot for Claude Code — bridge WeChat messages to Claude Code via the official ilink API",
  "type": "module",
  "bin": {
    "claude-code-wechat-channel": "cli.mjs"
  },
  "files": [
    "cli.mjs",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "esbuild setup.ts --bundle --platform=node --format=esm --outfile=dist/setup.js && esbuild wechat-bot.ts --bundle --platform=node --format=esm --external:@anthropic-ai/claude-agent-sdk --outfile=dist/wechat-bot.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "qrcode-terminal": "^0.12.0"
  },
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liangrk/claude-code-wechat-channel.git"
  },
  "keywords": [
    "claude-code",
    "wechat",
    "bot",
    "channel",
    "clawbot",
    "ai-agent"
  ]
}
